    "viem": "^2.47.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24",
    "@types/pg": "^8.18.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
